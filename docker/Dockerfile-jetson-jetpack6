# Cellia Jetson benchmarking image — layered on the prebuilt Ultralytics Jetson image.
# Adds JupyterLab (password-protected) and /storage + /notebooks mount points.
# Supports JetPack 6.1 on Jetson AGX Orin, Orin NX, and Orin Nano.

FROM ultralytics/ultralytics:latest-jetson-jetpack6

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_NO_CACHE_DIR=1 \
    PIP_BREAK_SYSTEM_PACKAGES=1

# JupyterLab for interactive benchmarking + pandas for results tables
RUN python3 -m pip install --upgrade pip && \
    python3 -m pip install jupyterlab notebook ipywidgets ipykernel pandas

# Bind-mount points (populated from host at runtime)
RUN mkdir -p /storage /notebooks && chmod -R a+w /storage /notebooks

# Entrypoint: hashes JUPYTER_PASSWORD and launches JupyterLab on :9443
COPY docker/run.sh /run.sh
RUN chmod +x /run.sh

EXPOSE 9443
CMD ["/run.sh"]

# Usage Examples -------------------------------------------------------------------------------------------------------

# Build (from repo root — context must include docker/run.sh)
# t=cellia/jetson-jetpack6:latest && sudo docker build --platform linux/arm64 -f docker/Dockerfile-jetson-jetpack6 -t $t .

# Run with NVIDIA runtime, /storage + /notebooks bind mounts, Jupyter port, and password from docker/.env
# cp docker/.env.example docker/.env   # then edit docker/.env to set JUPYTER_PASSWORD
# t=cellia/jetson-jetpack6:latest && sudo docker run -it --ipc=host --runtime=nvidia \
#   -p 9443:9443 \
#   --env-file docker/.env \
#   -v /storage:/storage \
#   -v $(pwd):/cellia \
#   --name cellia-bench $t
